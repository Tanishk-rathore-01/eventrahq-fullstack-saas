PORT=5050
NODE_ENV=development
JWT_SECRET=replace_with_a_long_random_secret_for_production
CLIENT_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120

# Required: backend-only Supabase service key. Never expose this in frontend code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional AI providers. Gemini is used first if present; OpenAI is fallback.
GEMINI_API_KEY=your_gemini_key_optional
OPENAI_API_KEY=your_openai_key_optional
