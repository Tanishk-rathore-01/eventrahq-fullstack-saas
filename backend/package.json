{
  "name": "@eventrahq/backend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "start": "node dist/server.js",
    "seed": "tsx src/scripts/seed.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@eventrahq/contracts": "2.0.0",
    "@google/genai": "2.9.0",
    "@supabase/supabase-js": "2.108.2",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.1.0",
    "pino": "10.1.0",
    "pino-http": "11.0.0",
    "qrcode": "1.5.4",
    "razorpay": "2.9.6",
    "resend": "6.14.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "24.10.4",
    "@types/qrcode": "1.5.6",
    "@types/supertest": "6.0.3",
    "eslint": "9.39.2",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.1",
    "vitest": "4.1.0"
  }
}
